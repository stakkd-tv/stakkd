#!/usr/bin/env ruby

# Lints the codebase using standardrb, eslint, and erb_lint
# Pass --fix to automatically fix linting errors
# If any command fails, exit with a non-zero status code

def cmd(command)
  puts "\n====== Running linter `##{command}`..."

  result = system(command)
  if result == false
    puts "Command failed: #{command}. See above output for linting errors."
    exit 1
  end
end

def check_for_focused_specs!
  puts "====== Checking for focused specs..."

  if system('grep -rE "^\s*(fdescribe|fcontext|fit|fscenario)\b" spec/')
    puts "Focused specs found. Please remove them before continuing."
    exit 1
  end
end

check_for_focused_specs!

if ARGV.include?("--fix")
  cmd("bundle exec standardrb --fix app spec lib")
  cmd("yarn lint:js --fix")
  cmd("bundle exec erb_lint -a --lint-all")
else
  cmd("bundle exec standardrb app spec lib")
  cmd("yarn lint:js")
  cmd("bundle exec erb_lint --cache --lint-all")
end

puts "\n====== No linting errors found!"
