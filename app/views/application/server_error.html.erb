<%
safe_trace = @error.backtrace
  .take(12)
  .map do |line|
    line
      .gsub(Rails.root.to_s, "[APP]") # strip app root
      .gsub(
        %r{.*?/gems/[^/]+/gems/([^/]+)/(.*)},
        '[GEMS]/\1/\2'
      )
  end
%>

<div class="w-full flex flex-col items-center justify-center gap-10 sm:mt-30">
    <svg height="172" viewBox="0 0 480 172" xmlns="http://www.w3.org/2000/svg" class="max-w-60 sm:max-w-120 w-full">
      <path d="m101.23 93.8427c-8.1103 0-15.4098 3.7849-19.7354 8.3813h-36.2269v-99.21891h103.8143v37.03791h-68.3984v24.8722c5.1366-2.7035 15.1396-5.9477 24.6014-5.9477 35.146 0 56.233 22.7094 56.233 55.4215 0 34.605-23.791 57.315-60.558 57.315-37.8492 0-61.64-22.169-63.8028-55.963h42.9857c1.0814 10.814 9.1919 19.195 21.6281 19.195 11.355 0 19.465-8.381 19.465-20.547 0-11.625-7.299-20.5463-20.006-20.5463zm138.833 77.8613c-40.822 0-64.884-35.146-64.884-85.7015 0-50.5554 24.062-85.700907 64.884-85.700907 40.823 0 64.884 35.145507 64.884 85.700907 0 50.5555-24.061 85.7015-64.884 85.7015zm0-133.2831c-17.572 0-22.709 21.8984-22.709 47.5816 0 25.6835 5.137 47.5815 22.709 47.5815 17.303 0 22.71-21.898 22.71-47.5815 0-25.6832-5.407-47.5816-22.71-47.5816zm140.456 133.2831c-40.823 0-64.884-35.146-64.884-85.7015 0-50.5554 24.061-85.700907 64.884-85.700907 40.822 0 64.884 35.145507 64.884 85.700907 0 50.5555-24.062 85.7015-64.884 85.7015zm0-133.2831c-17.573 0-22.71 21.8984-22.71 47.5816 0 25.6835 5.137 47.5815 22.71 47.5815 17.302 0 22.709-21.898 22.709-47.5815 0-25.6832-5.407-47.5816-22.709-47.5816z" fill="#f7567c"/>
    </svg>
  <h1 class="text-xl sm:text-4xl font-bold font-domine text-center px-4">We ran into an error.</h1>
  <p class="text-lg sm:text-xl px-4 text-center">
    We ran into an error while processing your request.
    Please open an issue on <a class="text-pop underline" href="https://github.com/stakkd-tv/stakkd/issues">Github</a>
    or contact support at <a class="text-pop underline" href="mailto:hello@stellarworks.dev">hello@stellarworks.dev</a>
    with the error details below:
  </p>
  <pre class="bg-background-darker p-4 overflow-auto max-w-full max-h-64 text-sm"><%= [
    "Error: #{@error.class}",
    "Message: #{@error.message}",
    "Request path: #{request.path}",
    "",
    "Stack trace:",
    *safe_trace
  ].join("\n") %></pre>
</div>
