<%= link_to person, class: "h-fit border border-pop rounded-lg overflow-hidden relative", data: {turbo: false} do %>
  <%= image_tag person.image(variant: :medium), class: "w-full aspect-2/3 object-cover" %>
    <div class="absolute w-full p-2 sm:p-4 bottom-0 left-0 bg-background/75 border-t border-pop">
    <div class="flex flex-col gap-2">
      <h3 class="text-sm sm:text-lg font-bold">
        <%= person.translated_name %>
        <% if person.original_name != person.translated_name %>
          <small> (<%= person.original_name %>)</small>
        <% end %>
      </h3>
      <span class="text-sm">
        <% if person.known_for %>
          <%= person.known_for.humanize %> -
        <% end %>
        <%= person.gender.humanize %>
      </span>
    </div>
  </div>
<% end %>
