<div class="max-w-2xl mx-auto h-full flex justify-center items-center px-6">
  <div class="flex flex-col w-full">
    <h3 class="text-4xl font-bold font-domine text-white mt-28 mb-10">Join the club</h3>
    <%= form_with model: @user, class: "flex flex-col gap-6" do |form| %>
      <div class="w-full">
        <%= form.text_field :username, required: true, autocomplete: "username", placeholder: "Username", value: params[:username], class: "w-full h-14 px-4 border-b-3 border-white focus:border-pop focus:outline-none data-field-error:border-red-400" %>
      </div>
      <div class="w-full">
        <%= form.email_field :email_address, required: true, autocomplete: "email", placeholder: "Email", value: params[:email_address], class: "w-full h-14 px-4 border-b-3 border-white focus:border-pop focus:outline-none data-field-error:border-red-400" %>
      </div>
      <div class="w-full">
        <%= form.password_field :password, required: true, autocomplete: "current-password", placeholder: "Password", maxlength: 72, class: "w-full h-14 px-4 border-b-3 border-white focus:border-pop focus:outline-none data-field-error:border-red-400" %>
      </div>
      <div class="w-full">
        <%= form.password_field :password_confirmation, required: true, autocomplete: "current-password", placeholder: "Confirm password", maxlength: 72, class: "w-full h-14 px-4 border-b-3 border-white focus:border-pop focus:outline-none data-field-error:border-red-400" %>
      </div>
      <div class="w-full">
        <label class="w-full mb-2 font-domine" for="trivia_answer"><%= @trivia[:question] %></label>
        <input type="text" id="trivia_answer" name="trivia_answer" autocomplete="off" placeholder="Trivia answer" class="w-full h-14 px-4 border-b-3 border-white focus:border-pop focus:outline-none data-field-error:border-red-400">
        <input type="hidden" name="trivia_question_name" value="<%= @trivia[:name] %>">
        <small class="mt-2 block">We ask this question to verify that you are human. If you need help, we accept the following answers (case insensitive): <%= @trivia[:answers].join(", ") %></small>
      </div>
      <div class="w-fit mt-10">
        <%= button_to do %>
          <div class="h-16 outline-3 outline-pop cursor-pointer px-6 flex gap-4 items-center text-white font-bold bg-pop/75 hover:bg-pop w-fit transition-all duration-300 ease-in-out">
            <i class="fa-solid fa-hand-point-right text-xl"></i>
            Let's go!
          </div>
        <% end %>
      </div>
    <% end %>
  </div>
</div>
