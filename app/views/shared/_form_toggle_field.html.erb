<div data-controller="toggle" id="<%= field.to_s %>">
  <label><%= field.to_s.humanize %></label>
  <%= form.check_box field, class: "hidden", autocomplete: "off", data: {toggle_target: "checkbox"} %>

  <div class="relative w-14 h-8 rounded-full cursor-pointer bg-background outline outline-pop transition-all duration-300 ease-in-out" data-toggle-target="toggleContainer" data-action="click->toggle#triggerToggle">
    <div class="w-6 h-6 rounded-full bg-white absolute top-1 left-1 transition-transform duration-300 ease-in-out" data-toggle-target="toggleHandle"></div>
  </div>
  <%= yield %>
</div>
