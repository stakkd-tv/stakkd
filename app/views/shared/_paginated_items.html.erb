<div class="flex flex-col sm:flex-row flex-wrap gap-6 justify-between items-end" data-controller="jump-to">
  <% if presenter.previous_item %>
    <%= link_to "Previous", presenter.previous_item_path, class: "link w-full sm:w-auto" %>
  <% else %>
    <p class="font-bold cursor-default py-2 px-4 border border-gray-400 text-gray-400 rounded-lg text-sm text-center w-full sm:w-auto">Previous</p>
  <% end %>
  <div class="flex-1 flex flex-col items-center w-full sm:w-auto">
    <p class="font-domine mb-2">Jump to</p>
    <select
      class="bg-background py-2 px-4 border border-pop rounded-lg focus:outline-pop focus:outline-1 w-full sm:w-auto"
      autocomplete="off"
      data-jump-to-target="select"
      name="jump_to">
      <% presenter.items.each do |item| %>
        <option value="<%= item.path %>" <% if item.selected %> selected<% end %>><%= item.name %></option>
      <% end %>
    </select>
  </div>
  <% if presenter.next_item %>
    <%= link_to "Next", presenter.next_item_path, class: "link w-full sm:w-auto" %>
  <% else %>
    <p class="font-bold cursor-default py-2 px-4 border border-gray-400 text-gray-400 rounded-lg text-sm text-center w-full sm:w-auto">Next</p>
  <% end %>
</div>
