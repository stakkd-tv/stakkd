<% content_for :title, "Stakkd - #{@movie.translated_title}" %>

<%= render "shared/colour_from_image", image: @movie.poster %>

<% if @movie.background(use_fallback: false) %>
  <div class="absolute -z-10 w-full h-96 overflow-hidden flex items-center justify-center">
    <%= image_tag @movie.background(use_fallback: false), class: "w-full min-h-96 object-cover blur-xs" %>
    <div class="absolute w-full h-full bg-linear-to-t from-background to-background/35"></div>
  </div>
<% end %>

<div class="max-w-7xl mx-auto my-8 px-6 pt-10">
  <div class="grid grid-cols-1 md:grid-cols-4 md:gap-8 md:min-h-screen">
    <div class="col-span-1 bg-background-darker rounded-lg p-4 flex flex-col gap-10 items-center md:items-start">
      <%= image_tag @movie.poster(variant: :medium), class: "max-h-40 w-fit md:w-full md:max-h-none rounded-lg" %>
      <div class="block md:hidden w-full">
        <h3 class="text-2xl font-bold font-domine text-white">
          <i class="fa-solid fa-video text-2xl mr-6"></i>
          <%= @movie.translated_title %>
        </h3>
        <% if @movie.genres.any? %>
          <div class="flex gap-3 flex-wrap mt-4">
            <% @movie.genres.each do |genre| %>
              <%= link_to genre.name, movies_path(genre_ids: [genre.id]), class: "rounded-full bg-pop/65 px-2 py-1 text-xs border-2 border-pop" %>
            <% end %>
          </div>
        <% end %>
        <% if @movie.tagline %>
          <p class="text-sm mt-4 italic"><%= @movie.tagline %></p>
        <% end %>
      </div>
      <div class="w-full grid grid-cols-2 sm:grid-cols-3 md:grid-cols-1 gap-10">
        <% if @movie.release_date %>
          <div>
            <p class="font-domine"><b>Release Date:</b></p>
            <p><%= @movie.release_date.strftime("%B %d, %Y") %></p>
          </div>
        <% end %>
        <div>
          <p class="font-domine"><b>Status:</b></p>
          <p><%= @movie.status.titleize %></p>
        </div>
        <div>
          <p class="font-domine"><b>Runtime:</b></p>
          <p><%= format_runtime(@movie) %></p>
        </div>
        <% if @movie.directors.any? %>
          <div>
            <p class="font-domine"><b>Directors:</b></p>
            <% @movie.directors.each do |director| %>
              <%= link_to director.person.translated_name, person_path(director.person), class: "underline" %><br>
            <% end %>
          </div>
        <% end %>
        <div>
          <p class="font-domine"><b>Budget:</b></p>
          <p>$<%= number_with_delimiter @movie.budget.to_i %></p>
        </div>
        <div>
          <p class="font-domine"><b>Revenue:</b></p>
          <p>$<%= number_with_delimiter @movie.revenue.to_i %></p>
        </div>
      </div>
      <% if @movie.companies.any? %>
        <%= render "shared/companies", companies: @movie.companies %>
      <% end %>
      <div class="flex gap-4 flex-col w-full">
        <%= link_to "Edit", edit_movie_path(@movie), class: "link" %>
        <div class="flex gap-4 w-full">
        <% if @movie.homepage.present? %>
          <%= link_to @movie.homepage, class: "link link-flex justify-center w-full" do %>
            <i class="fa-solid fa-globe text-2xl"></i>
          <% end %>
        <% end %>
        <% if @movie.imdb_url.present? %>
          <%= link_to @movie.imdb_url, class: "link link-imdb w-full" do %>
            <i class="fa-brands fa-imdb text-4xl"></i>
          <% end %>
        <% end %>
        </div>
      </div>
    </div>

    <div class="col-span-3 flex flex-col gap-10">
      <div class="hidden md:block">
        <h3 class="text-4xl font-bold font-domine text-white mt-10 md:mt-4">
          <i class="fa-solid fa-video text-4xl mr-6"></i>
          <%= @movie.translated_title %>
        </h3>
        <% if @movie.genres.any? %>
          <div class="flex gap-3 flex-wrap mt-4">
            <% @movie.genres.each do |genre| %>
              <%= link_to genre.name, movies_path(genre_ids: [genre.id]), class: "rounded-full bg-pop/65 px-3 py-1 text-sm border-2 border-pop" %>
            <% end %>
          </div>
        <% end %>
        <% if @movie.tagline %>
          <p class="text-sm mt-4 italic"><%= @movie.tagline %></p>
        <% end %>
      </div>
      <div class="mt-10 md:mt-0 leading-6 text-sm md:text-base flex flex-col gap-6">
        <p class="block sm:hidden text-xl font-domine">Overview:</p>
        <%= simple_format @movie.overview %>
      </div>

      <%= render "shared/cast_members", cast_members: @cast_members, full_cast_path: cast_movie_path(@movie) %>

      <%= render "shared/alternative_names", names_grouped_by_country: @alternative_names %>

      <% if @release_dates_for_country.any? %>
        <div class="rounded-lg border-2 border-pop bg-background overflow-hidden">
          <div class="flex gap-4 p-4 border-b-2 border-pop bg-background-darker">
            <%= image_tag @movie.country.flag, class: "w-5 min-w-5" %>
            <p><%= @movie.country.translated_name %></p>
          </div>
          <div class="flex flex-col gap-4">
            <table class="w-full">
              <% @release_dates_for_country.each do |release| %>
                <tr class="overflow-x-scroll">
                  <td class="p-4 w-0">
                    <%= release.date %>
                  </td>
                  <td class="p-4">
                    <%= release.type %>
                  </td>
                  <td class="p-4 w-0">
                    <%= release.certification.code %>
                  </td>
                  <td class="p-4">
                    <%= release.note %>
                  </td>
                </tr>
              <% end %>
            </table>
            <div class="p-4 pt-0 w-full">
              <%= link_to "View all releases", movie_releases_path(@movie), class: "link block w-full" %>
            </div>
          </div>
        </div>
      <% end %>

      <%= render "shared/galleries", presenter: @gallery_presenter %>

      <div class="flex flex-wrap gap-2">
        <% @movie.keywords.each do |keyword| %>
          <small class="rounded-lg bg-pop/50 px-3 py-1 text-sm border border-pop"><%= keyword %></small>
        <% end %>
      </div>
    </div>
  </div>
</div>
